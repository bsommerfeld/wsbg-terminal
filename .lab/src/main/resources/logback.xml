<?xml version="1.0" encoding="UTF-8"?>
<!--
  The lab's trace shows in the window. The underlying pipeline logs (Reddit
  fetch, [CLUSTER] decisions, vision results, editorial writes) go to the
  console (stderr) at INFO, so the launching terminal doubles as a detailed log.
-->
<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{0} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Quiet the chattiest per-item dumps; keep decision-level INFO. -->
    <logger name="dev.langchain4j" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDERR"/>
    </root>
</configuration>
