            <dependency>
                <groupId>org.mockito</groupId>
                <artifactId>mockito-junit-jupiter</artifactId>
                <version>5.11.0</version>
                <scope>test</scope>
            </dependency>
            <!-- JNA: native window-chrome calls on Windows (DWM dark title bar).
                 Core jar only; the dwmapi binding is hand-rolled, so jna-platform
                 isn't needed. -->
            <dependency>
                <groupId>net.java.dev.jna</groupId>
                <artifactId>jna</artifactId>
                <version>${jna.version}</version>
            </dependency>
            <!-- Tess4J: JNA binding to a system-installed Tesseract for the mechanical
                 OCR read of Reddit images (vision model is retired). PDF support is
                 excluded — we only ever OCR in-memory screenshots. -->
            <dependency>
                <groupId>net.sourceforge.tess4j</groupId>
                <artifactId>tess4j</artifactId>
                <version>${tess4j.version}</version>
                <exclusions>
                    <exclusion>
                        <groupId>org.apache.pdfbox</groupId>
                        <artifactId>*</artifactId>
                    </exclusion>
                </exclusions>
            </dependency>
        </dependencies>
