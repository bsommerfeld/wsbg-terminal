            <!-- JavaFX retained ONLY for the launcher module's installer UI.
                 The main terminal app runs as Swing + JCEF, no JavaFX in
                 the runtime classpath of the terminal module. -->
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-controls</artifactId>
                <version>${javafx.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-fxml</artifactId>
                <version>${javafx.version}</version>
            </dependency>
            <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-web</artifactId>
                <version>${javafx.version}</version>
            </dependency>
             <dependency>
                <groupId>org.openjfx</groupId>
                <artifactId>javafx-graphics</artifactId>
                <version>${javafx.version}</version>
            </dependency>

            <!-- JCEF: embedded Chromium for the main terminal UI.
                 Auto-downloads native binaries to ~/jcef-bundle on first run.
                 Chromium 132 ships modern CSS (oklch, container queries,
                 :has()) and a current V8 — required for the dashboard's
                 oklch-based color tokens. -->
            <dependency>
                <groupId>me.friwi</groupId>
                <artifactId>jcefmaven</artifactId>
                <version>${jcefmaven.version}</version>
            </dependency>

            <!-- Java-WebSocket: tiny, no transitive deps. Used to push
                 live updates (headlines, fj-news, market-hours) from
                 the Java backend to the JCEF frontend with zero polling. -->
            <dependency>
                <groupId>org.java-websocket</groupId>
                <artifactId>Java-WebSocket</artifactId>
                <version>${java-websocket.version}</version>
            </dependency>


